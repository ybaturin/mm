# .env.example — copy to .env and fill in. NEVER commit .env (it is gitignored).

# Mode
BROKER=fake            # fake | ibkr
STRATEGY=claude        # claude | fake
PANEL=on               # on | off
NOTIFIER=telegram      # telegram | fake
FLOOR_FRACTION=0.8

# Secrets
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# IBKR (only when BROKER=ibkr) — Gateway on this host or a reachable x86 box
IBKR_HOST=127.0.0.1
IBKR_PORT=4002         # paper Gateway; 4001 = live
IBKR_CLIENT_ID_BASE=1
# One IBKR account per agent (no commingling), in profile order. Leave blank for a
# single default account. e.g. IBKR_ACCOUNTS=DU111,DU222,DU333
IBKR_ACCOUNTS=
# Real money (live port 4001) is blocked until the track record beats SPY; set to 1 to bypass.
GO_LIVE_OVERRIDE=
